<?xml version="1.0" encoding="UTF-8"?>
<CustomObject xmlns="http://soap.sforce.com/2006/04/metadata">
    <actionOverrides>
        <actionName>View</actionName>
        <content>Cursor_Batch_Job_Parent_Record_Page</content>
        <formFactor>Large</formFactor>
        <skipRecordTypeSelect>false</skipRecordTypeSelect>
        <type>Flexipage</type>
    </actionOverrides>
    <actionOverrides>
        <actionName>View</actionName>
        <content>Cursor_Batch_Job_Parent_Record_Page</content>
        <formFactor>Small</formFactor>
        <skipRecordTypeSelect>false</skipRecordTypeSelect>
        <type>Flexipage</type>
    </actionOverrides>
    <compactLayoutAssignment>Cursor_Batch_Job_Parent_Compact</compactLayoutAssignment>
    <deploymentStatus>Deployed</deploymentStatus>
    <description>Persistent parent record for a metadata-defined CursorBatch job. There is one parent per CursorBatch_Config__mdt, keyed 1:1 by Config_Developer_Name__c (Salesforce does not permit Lookup fields targeting custom metadata records, so a unique external-ID text field enforces the relationship). All CursorBatch_Job__c runs of the same job (same MasterLabel/DeveloperName) link to this single parent via the Job_Parent__c lookup.</description>
    <label>Cursor Batch Job Parent</label>
    <nameField>
        <displayFormat>CBJP-{0000000}</displayFormat>
        <label>Parent Number</label>
        <type>AutoNumber</type>
    </nameField>
    <pluralLabel>Cursor Batch Job Parents</pluralLabel>
    <searchLayouts>
        <searchResultsAdditionalFields>Config_Developer_Name__c</searchResultsAdditionalFields>
        <searchResultsAdditionalFields>Config_Label__c</searchResultsAdditionalFields>
        <searchResultsAdditionalFields>Last_Job_Status__c</searchResultsAdditionalFields>
        <searchResultsAdditionalFields>Last_Job_Started_At__c</searchResultsAdditionalFields>
    </searchLayouts>
    <sharingModel>ReadWrite</sharingModel>
</CustomObject>
